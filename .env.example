# ====== OtterHub 环境变量配置 ======
# 复制此文件为 .env，然后填写实际值

# ---------- 必填 ----------

# PASSWORD：Web 页面登录密码（用于浏览器端 /auth/login）
PASSWORD=your_secure_password_here

# JWT_SECRET：JWT 令牌签名密钥（用于登录会话加密）
# 生成方式：openssl rand -hex 32
JWT_SECRET=your_strong_jwt_secret_here

# ---------- 生产环境必填 ----------

# TG_CHAT_ID：Telegram 对话 ID
# 向 @userinfobot 发送任意消息获取
TG_CHAT_ID=your_telegram_chat_id

# TG_BOT_TOKEN：Telegram Bot 令牌
# 向 @BotFather 发送 /newbot 创建机器人获取
TG_BOT_TOKEN=your_telegram_bot_token

# ---------- 可选 ----------

# API_TOKEN：API 接口访问密钥（用于程序化调用，非浏览器登录）
# 生成方式：openssl rand -hex 32
# 调用时使用请求头：Authorization: Bearer <API_TOKEN>
API_TOKEN=your_secure_api_token_here

# NODE_ENV：运行环境（development / production）
NODE_ENV=development

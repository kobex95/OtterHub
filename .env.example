# Environment Variables for OtterHub

# Required: Password for admin authentication (used in /auth/login)
PASSWORD=your_secure_password_here

# Required: API token for programmatic access (used in API key authentication)
API_TOKEN=your_secure_api_token_here

# Strongly recommended: JWT secret for signing authentication tokens
# If not set, the system will use PASSWORD as fallback (less secure)
JWT_SECRET=your_strong_jwt_secret_here

# Optional: Set other environment variables as needed
# NODE_ENV=development|production
